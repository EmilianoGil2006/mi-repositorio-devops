# 1. Usar una imagen base de Python
FROM python:3.9-slim

# 2. Establecer el directorio de trabajo dentro del contenedor
WORKDIR /app

# 3. Copiar el archivo de requisitos e instalar Flask
# (Como es un ejemplo simple, instalamos flask directamente)
RUN pip install flask

# 4. Copiar el código de la aplicación al contenedor
COPY app.py .

# 5. Exponer el puerto donde corre Flask
EXPOSE 5000

# 6. Comando para ejecutar la aplicación
CMD ["python", "app.py"]